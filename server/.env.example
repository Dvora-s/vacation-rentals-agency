# Server
PORT=5000

# MySQL (Railway)
# `*.railway.internal` — רק כשהאפליקציה רצה על Railway. במחשב מקומי: שימוש ב־hostname הציבורי מ־DATABASE_URL (למשל *.proxy.rlwy.net), או הגדרת DB_HOST ידנית.
# אם DB_HOST נשאר internal וקיים DATABASE_URL ציבורי — השרת יחליף אוטומטית ל־host מה־URL (ראו db.js).
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=UwIOWtEuBNxgKXgMORyVCExBHorWvRKA
DB_NAME=railway
DB_SSL_MODE=REQUIRED

# Full connection URI (optional - used as fallback)
DATABASE_URL=mysql://root:UwIOWtEuBNxgKXgMORyVCExBHorWvRKA@acela.proxy.rlwy.net:24797/railway

# JWT — לאוטנטיקציה
JWT_SECRET=3533595bcb3b432356e423f2028f8a6fbbac972aa281f259e6fe65775587c61de1be25ca620b9256b0b0f758c1082729
JWT_EXPIRES_IN=7d

# SMTP — לשליחת מיילים (עובד מקומית; ב-Railway Gmail SMTP לעיתים נחסם — ראו Resend למטה)
# לדוגמה עבור Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587 (מומלץ בענן), SMTP_USER=האימייל,
# SMTP_PASS=App Password (לא הסיסמה הרגילה!).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tivuch.shabat@gmail.com
SMTP_PASS=
SMTP_FROM=דירות נופש <tivuch.shabat@gmail.com>
SMTP_TLS_INSECURE=true

# Resend (מומלץ ב-Railway) — שליחה דרך HTTPS
# RESEND_API_KEY=re_...  (מ-resend.com → API Keys)
# EMAIL_FROM חייב להיות מהדומיין המאומת (לא onboarding@resend.dev)
RESEND_API_KEY=
EMAIL_FROM=דירות נופש <noreply@dirotnofesh.co.il>
# RESEND_FROM — alias ל-EMAIL_FROM (אופציונלי)
RESEND_FROM=

# ────────── Cloudinary — העלאת תמונות דירות (מומלץ ב-Railway) ──────────
# Dashboard: https://console.cloudinary.com → Account Details (למעלה/Settings)
# ⚠️ CLOUDINARY_CLOUD_NAME = השדה "Cloud name" (למשל dq8abc12x) — לא שם תיקייה "Root" ב-Media Library!
# אפשרות א': שלושה משתנים (מומלץ):
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# אפשרות ב': משתנה אחד (מ-Cloudinary → API Environment variable):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# תיקייה בענן (אופציונלי — ברירת מחדל dirotnofesh/apartments):
# CLOUDINARY_FOLDER=dirotnofesh/apartments

# כתובת בסיס של אתר הלקוח — לבניית קישורים במיילים (אימות, איפוס סיסמה).
APP_URL=https://vacation-rentals-agency1.vercel.app

# תזכורת ראשונה: כמה ימים לפני פקיעת התוקף לשלוח אותה (ברירת מחדל: 7).
EXPIRY_REMINDER_DAYS=7
# תזכורת אחרונה: כמה ימים לפני הפקיעה לשלוח תזכורת נוספת אם לא חודשה (ברירת מחדל: 1).
EXPIRY_FINAL_REMINDER_DAYS=1

# התחברות עם גוגל — Client ID מ-Google Cloud Console (OAuth 2.0).
# יש ליצור OAuth Client (Web) ולהוסיף את כתובת האתר ל-Authorized JavaScript origins.
# כל עוד ריק — כפתור "התחברות עם Google" יהיה מוסתר והתחברות גוגל מושבתת.
GOOGLE_CLIENT_ID=

# כתובת לקבלת התראות מנהל (פרסום דירה חדשה / פניות "צור קשר"). ניתן לפצל בכמה כתובות עם פסיק.
ADMIN_NOTIFY_EMAIL=tivuch.shabat@gmail.com

# חשבון מנהל — נוצר אוטומטית בעליית השרת אם המייל לא קיים עדיין.
ADMIN_EMAIL=admin@nofesh.local
ADMIN_PASSWORD=Admin1234!

# ────────── PayPal (Orders API — server-side secret) ──────────
# Sandbox app: https://developer.paypal.com/dashboard/applications/sandbox
# 1) Railway (שרת): PAYPAL_CLIENT_ID + PAYPAL_CLIENT_SECRET מאותה אפליקציה
# 2) Vercel (לקוח): VITE_PAYPAL_CLIENT_ID = אותו Client ID (ללא Secret!)
# 3) אותו מצב: sandbox בפיתוח, live בפרודקשן
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live — קובע את כתובת ה-API אם PAYPAL_API_BASE ריק
PAYPAL_MODE=sandbox
# PAYPAL_TLS_INSECURE: false = אימות TLS מלא. true = ללא אימות תעודה מול PayPal.
# בפיתוח מקומי (לא ענן, NODE_ENV לא production) — ברירת מחדל כבר עוקפת TLS; אפשר PAYPAL_TLS_INSECURE=false לכיבוי.
# PAYPAL_TLS_INSECURE=true
# אופציונלי — דורס את PAYPAL_MODE:
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# PAYPAL_API_BASE=https://api-m.paypal.com

# ────────── PayMe (server-side only — never put secrets in VITE_*) ──────────
PAYME_API_KEY=
# PayMe API base (no trailing slash). Production: https://live.payme.io/api | Sandbox (default): https://sandbox.payme.io/api
PAYME_BASE_URL=https://live.payme.io/api
# Merchant / seller id from PayMe dashboard (seller_payme_id) — required by most accounts
PAYME_MERCHANT_ID=
# Public backend URL for IPN (Railway). Example:
# API_PUBLIC_URL=https://vacation-rentals-agency-production.up.railway.app
# API endpoint path (default: /generate-sale). Alternative: /generate-payment
# PAYME_GENERATE_PAYMENT_PATH=/generate-sale
# PAYME_GET_STATUS_PATH=/payments/:id
# PAYME_VERIFY_PAYMENT_PATH=/payments/:id/verify
# PAYME_HTTP_TIMEOUT_MS=20000
# Optional: tighten create endpoint rate limit (per IP / 15 minutes)
# RATE_LIMIT_PAYME_CREATE_MAX=60
