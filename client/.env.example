# API base URL — פרודקשן: כתובת מלאה ל־API (כולל /api). בפיתוח אפשר להשאיר ריק ולהשתמש ב־VITE_API_BASE=/api עם פרוקסי של Vite.
# VITE_API_URL=https://vications-apartments-node-repo-production.up.railway.app/api
# בפיתוח מקומי מול שרת Node על פורט 5000:
# VITE_API_URL=http://localhost:5000/api
# Explicit API prefix for `fetch` helpers (optional; default is `/api` when VITE_API_URL is unset):
# VITE_API_BASE=/api

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# Support contact (displayed on contact page)
VITE_SUPPORT_EMAIL=tivuch.shabat@gmail.com
VITE_SUPPORT_PHONE=053-8882145

# Mock mode: רק כש־VITE_USE_MOCK=true — נתוני דמו מקומיים. בלי שורה או עם false — נתונים מהשרת.
VITE_USE_MOCK=false

# PayPal (public — used only by the JS SDK in the browser; must match Sandbox or Live app)
VITE_PAYPAL_CLIENT_ID=
