# Server
PORT=5000

# Aiven MySQL Database
DB_HOST=your-host.aivencloud.com
DB_PORT=10137
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_NAME=defaultdb
DB_SSL_MODE=REQUIRED

# Full connection URI (optional)
DATABASE_URL=mysql://avnadmin:your-password@your-host.aivencloud.com:10137/defaultdb?ssl-mode=REQUIRED

# JWT secret for authentication tokens
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d

# SMTP — for sending emails (welcome email on registration)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465,
# SMTP_USER=you@gmail.com, SMTP_PASS=your-app-password (NOT your normal password)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Email address that receives admin notifications (new listing pending approval).
# Comma-separated for multiple recipients. Falls back to admin users in DB.
ADMIN_NOTIFY_EMAIL=
