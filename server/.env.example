# Server
PORT=5000
NODE_ENV=development

# ─── CORS (פרודקשן) ───
# כתובות ה-frontend המורשות (מופרדות בפסיקים). חובה בפרודקשן!
# דוגמה: CORS_ORIGINS=https://your-site.com,https://www.your-site.com
CORS_ORIGINS=
CLIENT_ORIGIN=

# ─── Rate Limiting ───
# מקסימום בקשות לנתיבי אימות (login/register) ב-15 דקות לכל IP
RATE_LIMIT_AUTH_MAX=20
# מקסימום בקשות לנתיבים רגישים (שכחתי סיסמה, שליחה חוזרת) בשעה לכל IP
RATE_LIMIT_SENSITIVE_MAX=10

# Aiven MySQL Database
DB_HOST=your-host.aivencloud.com
DB_PORT=10137
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_NAME=defaultdb
DB_SSL_MODE=REQUIRED

# Full connection URI (optional)
DATABASE_URL=mysql://avnadmin:your-password@your-host.aivencloud.com:10137/defaultdb?ssl-mode=REQUIRED

# JWT secret for authentication tokens
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d

# SMTP — for sending emails (welcome email on registration)
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465,
# SMTP_USER=you@gmail.com, SMTP_PASS=your-app-password (NOT your normal password)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Base URL of the client site — used to build links inside emails.
APP_URL=http://localhost:3000

# Public API URL (for email links like one-click approve). Defaults to APP_URL/api
PUBLIC_API_URL=

# Google OAuth (server-side ID token verification)
GOOGLE_CLIENT_ID=

# Listing expiry reminders: first reminder N days before expiry (default 7),
# and a final reminder N days before expiry if not renewed (default 1).
EXPIRY_REMINDER_DAYS=7
EXPIRY_FINAL_REMINDER_DAYS=1

# Email address that receives admin notifications (new listing pending approval).
# Comma-separated for multiple recipients. Falls back to admin users in DB.
ADMIN_NOTIFY_EMAIL=

# Admin account (auto-created on first server start if email does not exist)
ADMIN_EMAIL=admin@nofesh.local
ADMIN_PASSWORD=Admin1234!
