# API base URL (production: https://your-api-domain.com/api)
# The React code defaults `VITE_API_BASE` to `/api` (Vite dev proxy). Use VITE_API_URL only if your project reads it.
VITE_API_URL=http://localhost:5000/api
# Explicit API prefix for `fetch` helpers (optional; default is `/api`):
# VITE_API_BASE=/api

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=

# Support contact (displayed on contact page)
VITE_SUPPORT_EMAIL=tivuch.shabat@gmail.com
VITE_SUPPORT_PHONE=053-8882145

# Mock mode: רק כש־VITE_USE_MOCK=true — נתוני דמו מקומיים. בלי שורה או עם false — נתונים מהשרת.
VITE_USE_MOCK=false

# PayPal (public — used only by the JS SDK in the browser; must match Sandbox or Live app)
VITE_PAYPAL_CLIENT_ID=
