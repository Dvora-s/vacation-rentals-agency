{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix client --include=dev",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://vacation-rentals-agency-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!google[a-f0-9]+\\.html).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "/api",
      "VITE_PAYPAL_CLIENT_ID": "Abkuo4QGQA6E99RDxPMgSWDc04Wgaov1tfCI6DxMmV-CL_E_r1EOiJuQBsaEjoZzppnmxNA38RZG3tEm",
      "VITE_PAYPAL_MODE": "sandbox"
    }
  }
}
