      "destination": "https://vacation-rentals-agency-production.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "/api",
      "VITE_PAYPAL_CLIENT_ID": "AQU-qcKfm9iHr_0KvhilZ9nHvvF-VjVosTMz9odFEH-SKLuGIBISrcPMJeSevlOrDeD9TeDD3MVGuQTI",
      "VITE_PAYPAL_MODE": "live"
    }
  }
}
