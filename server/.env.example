# Server
PORT=5000

# Aiven MySQL Database
DB_HOST=your-host.aivencloud.com
DB_PORT=10137
DB_USER=avnadmin
DB_PASSWORD=your-password
DB_NAME=defaultdb
DB_SSL_MODE=REQUIRED

# Full connection URI (optional)
DATABASE_URL=mysql://avnadmin:your-password@your-host.aivencloud.com:10137/defaultdb?ssl-mode=REQUIRED

# JWT secret for authentication tokens
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=please-change-me
JWT_EXPIRES_IN=7d

# Admin account (auto-created on first server start if email does not exist)
ADMIN_EMAIL=admin@nofesh.local
ADMIN_PASSWORD=Admin1234!
